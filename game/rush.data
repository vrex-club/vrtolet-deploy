[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","RUSH","description","У вас есть уникальная возможность разбежавшись прыгнуть со скалы! Rush — это очень реалистичный (как, впрочем и остальные VR игры) симулятор костюма-крыла. Вы прыгаете со скалы в компании таких же экстремалов и летите с дикой скоростью по замысловатому маршруту между скал. Цель —  обогнать других, все просто, но душа уходит в пятки!","thumb","/content/uploads/2020/02/Rush-1038x576.jpg","video","https://steamcdn-a.akamaihd.net/steam/apps/256742434/movie_max.webm"]

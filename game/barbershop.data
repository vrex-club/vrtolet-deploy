[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","Barbershop Simulator VR","description","Очень забавный симулятор парикмахера! Очень жаль, что разработчики не смогли добавить эмоции посетителей после того, что с ними сотворил игрок! В реальной жизни после таких экспериментов над внешним видом клиента, парикмахер должен проявить чудеса быстроты бега)","thumb","/content/uploads/2023/01/Barber.jpg","video","https://www.youtube.com/watch?v=_tQVGvbnGNk"]

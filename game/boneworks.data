[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","Boneworks","description","Одна из лучших VR игр! Шутер от первого лица с упором на реалистичную физику. В игре можно взаимодействовать во всеми предметами, которые находишь. Вообще со всеми! Можно проходить компанию с кучей головоломок, которые можно проходить разными способами, или запустить «песочницу» где сразу найти оружие кого-нибудь убить","thumb","/content/uploads/2022/01/Boneworks-1038x576.jpg","video","https://www.youtube.com/watch?v=_tQVGvbnGNk"]

[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","Zombie Training Simulator","description","Милая детская игра про милых картонных зомби. Думать не надо, жми на курок, уничтожай, бросай гранаты, взрывай канистры с бензином, делай что хочешь. Задача отбиться. Чем больше убьешь, тем лучше оружие получишь, все очень просто. Наслаждаемся)","thumb","/content/uploads/2020/11/Zombie-training-1038x576.jpg","video","https://www.youtube.com/watch?v=Yd92SbQcfmI"]

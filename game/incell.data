[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","InCell VR","description","Удивительно красивая игра на тему строения клеток и борьбы с вирусами в микромире. Но несмотря на научную «основу» это все-таки не более чем игра. Напоминает американские горки.","thumb","/content/uploads/2020/02/InCell-1038x576.jpg","video","https://www.youtube.com/watch?v=Ua537N6KBQI"]

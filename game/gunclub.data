[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","Gun Club VR","description","Стрелковый клуб, а точнее говоря очень навороченный тир с огромным выбором стволов, которые можно тестировать как на обычных мишенях, так и на нестандартных — вроде полчищ живых мертвецов.","thumb","/content/uploads/2020/02/Gun-Club-1038x576.jpg","video","https://steamcdn-a.akamaihd.net/steam/apps/256742447/movie480.webm"]

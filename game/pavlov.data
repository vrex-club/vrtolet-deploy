[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","Pavlov VR","description","Pavlov VR — Командный шутер от первого лица в виртуальной реальности, поразительно напоминающий CounterStrike. По сравнению с прообразом, сюда добавлены новые игровые режимы, среди которых не обошлось и без зомби, а так же тонны нового оружия.","thumb","/content/uploads/2020/02/Pavlov-1038x576.jpg","video","https://www.youtube.com/watch?v=iLZTKzm1Y-w"]

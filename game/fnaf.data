[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","Five Nights at Freddy’s: Help Wanted","description","Любимый хоррор наших юных гостей!  Вы — ночной охранник в пиццерии, по которой ночью бегают некие аниматроники. Днем они работают в этом заведении, а ночью разминаются, чтобы не заржаветь. Ну и заодно пугают вас!","thumb","/content/uploads/2022/10/FNAF-1038x576.jpg","video","https://www.youtube.com/watch?v=-tJzG0QleXU"]

[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","Angry Birds VR: Isle of Pigs","description","Злые птички по прежнему злые, свинтусы по прежнему зеленые и наглые. Но к сожалению для свинтусов целится из рогатки стало намного удобнее, а стрелять теперь можно с разных сторон, не спрячешься!","thumb","/content/uploads/2020/02/Angry.png","video","https://www.youtube.com/watch?v=87cBPQlTJgw"]

[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","Curious Cases","description","В этой истории, состоящей из 3 глав, вы играете современную легенду — детектива Томаса Мура. Им раскрыто больше дел, чем можно себе представить. Он приступил к работе сразу же, как только другие зашли в тупик. Играть можно с друзьями","thumb","/content/uploads/2020/10/CuriousCases-1038x576.jpg","video","https://www.youtube.com/watch?v=0yUXR7A4DwU"]

[{"_1":2},"routes/game",{"_3":4},"data",{"_5":6,"_7":8,"_9":10,"_11":12},"name","Hyper Dash","description","Командный шутер! Играем за роботов против таких же роботов, но другого цвета. Можно играть до 6 человек друг против друга или против ботов. Есть несколько режимов: захват флага, доминирование или просто максимум фрагов. Из фишек — весьма эффективный рывок, скольжение по рельсам, а так же разные усилители и щиты. Очень динамично и захватывающе!","thumb","/content/uploads/2025/10/Hyper-1038x576.jpg","video","https://www.youtube.com/watch?v=BOivB5Et06k"]
